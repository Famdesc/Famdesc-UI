---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import HeroSectionAlt from "@components/sections/landing/HeroSectionAlt.astro";
import FeaturesGeneral from "@components/sections/features/FeaturesGeneral.astro";
import FeaturesNavs from "@components/sections/features/FeaturesNavs.astro";
import TestimonialsSection from "@components/sections/testimonials/TestimonialsSection.astro";
import MainSection from "@components/ui/blocks/MainSection.astro";
import FAQ from "@components/sections/misc/FAQ.astro";
import AnnouncementBanner from "@components/ui/banners/AnnouncementBanner.astro";
import heroImage from "@images/hero-image-light.avif";
import heroImageDark from "@images/hero-image-dark.avif";
import faqs from "@data/es/faqs.json";
import features from "@data/es/features.json";
import fsaLine from "@images/fsa-line.avif";
import fsaOneLinePro from "@images/fsa-one-line-pro.avif";
import { getRelativeLocaleUrl } from "astro:i18n";
import ClientsSliderSection from "@/components/sections/landing/ClientsSliderSection.astro";
import TestimonialData from "@utils/testimonialsData";
import { famdescPromo } from "@/videos/videosLink";

const avatarSrcs: Array<string> = [
  "https://images.unsplash.com/photo-1568602471122-7832951cc4c5?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1531927557220-a9e23c1e4794?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1541101767792-f9b2b1c4f127?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&&auto=format&fit=facearea&facepad=3&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
];
---

<MainLayout lang="es">
  <AnnouncementBanner
    title="Orgullosamente Open Source"
    btnId="dismiss-button"
    btnTitle="Explore Famdesc en GitHub"
    url="https://github.com/Famdesc/Famdesc-UI"
  />

  <HeroSection
    title=`<span class="text-salmon-500 dark:text-salmon-400">Famdesc:</span> Tecnología para personas. Creada para familias.`
    subTitle="Famdesc es una compañía tecnológica centrada en las personas y las familias. Comenzamos con productos de audio premium a través de FSA mientras construimos el futuro de una plataforma social familiar privada."
    primaryBtn="Explorar FSA Line One Pro"
    primaryBtnURL="/products/fsa-line-one-pro"
    secondaryBtn="Unirse a la lista"
    secondaryBtnURL={getRelativeLocaleUrl("es", "contact")}
    withReview={true}
    avatars={avatarSrcs}
    rating=`<span class="font-bold">4.8</span> / 5`
    starCount={4}
    reviews=`Desde más de <span class="font-bold">12.8k</span> reseñas`
    src={heroImage}
    srcDark={heroImageDark}
    alt="Banner de la empresa tecnológica Famdesc con un laboratorio luminoso y minimalista, diagramas holográficos y el logo de la marca."
  />

  <FeaturesGeneral
    title="Famdesc: Tecnología para personas y familias."
    subTitle="Famdesc está construyendo tecnología para las personas y las familias. Nuestro primer paso es FSA, una línea de audio premium diseñada para entregar valor real hoy mientras apoyamos el desarrollo a largo plazo de una plataforma social familiar privada."
    src={famdescPromo}
    alt="Video promocional que muestra la evolución de Famdesc: desde soluciones de hardware de alta fidelidad como la línea de audio FSA, hasta herramientas del ecosistema diseñadas para mantener a las familias conectadas y seguras."
    features={features}
  />

  <FeaturesNavs
    buttonConfig={{
      btnExists: false,
    }}
    title={`Famdesc <span class="text-salmon-500 dark:text-salmon-400">Sound Authority</span>`}
    subtitle="FSA es la primera línea tecnológica premium dentro del ecosistema Famdesc, enfocada en productos de audio confiables y útiles hoy."
    tabs={[
      {
        heading: "Primera Línea Premium",
        content:
          "Famdesc Sound Authority (FSA) presenta la primera línea de productos reales del ecosistema Famdesc, empezando con audio in-ear cableado premium.",
        svg: "tools",
        src: fsaLine,
        alt: "Banner de la línea de audio FSA dentro de un laboratorio de ingeniería alto rendimiento, con analizadores de frecuencia, bobinas de cobre y componentes de audio de precisión.",
        first: true,
      },
      {
        heading: "Diseñado para la Durabilidad",
        content:
          "FSA Line One Pro ofrece Enhanced Hi-Fi Sound con driver dinámico de 10 mm, aislamiento de ruido, micrófono HD, cable trenzado reforzado, carcasa metálica y conector 3.5 mm chapado en oro en forma de L.",
        svg: "dashboard",
        src: fsaOneLinePro,
        alt: "Exhibición comercial de los audífonos FSA Line One Pro con su acabado de aluminio, cable trenzado, micrófono integrado y especificaciones acústicas técnicas.",
        second: true,
      },
    ]}
  />

  <ClientsSliderSection
    title="Cumplimiento en Proceso"
    subTitle="FSA Line One Pro está diseñado para cumplir requisitos CE, FCC, RoHS y WEEE. Se han solicitado al proveedor los PDFs actualizados antes de usar claims de certificación más fuertes."
    testimonialsData={TestimonialData.esSliderData}
  />

  <MainSection
    title="Presentando FSA — Famdesc Sound Authority."
    subTitle="Productos de audio cableado premium diseñados para uso confiable, baja latencia y sin batería."
    btnExists={true}
    btnTitle="Ver productos FSA"
    btnURL="/products"
  />

  <TestimonialsSection
    title="La plataforma social Famdesc (en desarrollo)"
    subTitle="Estamos desarrollando el siguiente capítulo de Famdesc: una futura plataforma social construida sobre nuestra base tecnológica y de hardware. A medida que Famdesc Technology crece con líneas como FSA, seguimos construyendo herramientas sociales con sentido que mantienen a las familias conectadas."
    testimonials={[
      {
        content:
          "Famdesc comenzó como una visión social y ahora evoluciona hacia una empresa tecnológica que crea productos reales primero. Este camino nos permite financiar innovación sostenible y regresar más fuertes con una plataforma diseñada para conectar a las familias de maneras más profundas y prácticas.",
        author: "Equipo Famdesc",
        role: "Visión de Tecnología y Comunidad",
        avatarSrc:
          "https://raw.githubusercontent.com/nardis9501/avatar/main/yuri.avif",
      },
    ]}
    statistics={[
      {
        count: "1.º",
        description:
          "línea tecnológica lanzada a través de Famdesc Sound Authority como el primer paso de nuestra estrategia paraguas.",
      },
      {
        count: "Futuro",
        description:
          "plataforma social en planificación activa, informada por la experiencia real de construir productos y la retroalimentación de la comunidad.",
      },
      {
        count: "Real",
        description:
          "enfoque soluciones-primero para financiar el crecimiento y sostener la innovación a largo plazo para las familias.",
      },
      {
        count: "Familia",
        description:
          "misión central preservada: construir tecnología que ayuda a las personas a mantenerse conectadas entre generaciones.",
      },
    ]}
  />

  <FAQ title="Preguntas<br />frecuentes" faqs={faqs} />

  <HeroSectionAlt
    title="Construyamos Juntos"
    subTitle="Famdesc combina la colaboración de código abierto con una protección comercial responsable. El frontend está abierto para que los desarrolladores puedan explorarlo y contribuir, mientras que el backend permanece disponible para auditoría con el fin de apoyar la transparencia, la seguridad y un crecimiento sostenible."
    url="https://github.com/Famdesc/Famdesc-UI"
  />
</MainLayout>
