---
// Importing necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import CardSmall from "@components/ui/cards/CardSmall.astro";
import FeaturesStatsAlt from "@components/sections/features/FeaturesStatsAlt.astro";

// Importing necessary functions from Astro
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { SITE } from "@data/constants";
import TestimonialsSectionAlt from "@/components/sections/testimonials/TestimonialsSectionAlt.astro";
import CardWide from "@/components/ui/cards/CardWide.astro";

// Fetching all the product related content and sorting it by main.id
const product: CollectionEntry<"products">[] = (
  await getCollection("products")
).sort(
  (a: CollectionEntry<"products">, b: CollectionEntry<"products">) =>
    a.data.main.id - b.data.main.id,
);

// Define variables for page content
const title: string = "Productos FSA";
const subTitle: string =
  "Famdesc Sound Authority es la primera línea tecnológica premium dentro del ecosistema Famdesc. Nuestro producto estrella actual es FSA Line One Pro, un producto de audio intraauricular con cable diseñado para una escucha fiable de baja latencia sin necesidad de baterías ni recargas.";

const pageTitle: string = `Productos | ${SITE.title}`;

const testimonials = [
  // First testimonial data
  {
    content:
      ' "FSA se siente como una marca con una visión clara: tecnología moderna, útil y creada con atención al detalle. Los audífonos FSA One Line Pro se ven elegantes, prácticos y preparados para el uso diario. Es emocionante ver un producto con tanta identidad y ambición." ',
    author: "Lian Steffan",
    role: "Estudiante de Estomatología",
    avatarSrc:
      "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=1374&auto=format&fit=crop&ixlib=rb-4.0.3&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80",
    avatarAlt: "Retrato de Lian Steffan",
  },
  // Second testimonial data
  {
    content:
      ' "Lo que más me gusta de FSA es cómo el producto combina estilo, tecnología y una presencia de marca fuerte. Los audífonos se sienten como algo diseñado no solo para usarse, sino también para representar confianza, progreso y buen gusto." ',
    author: "Emine",
    role: "Estudiante y trabajadora en el área comercial",
    avatarSrc:
      "https://images.unsplash.com/photo-1544005313-94ddf0286df2?q=80&w=1376&auto=format&fit=crop&ixlib=rb-4.0.3&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80",
    avatarAlt: "Retrato de Emine",
  },
  // Third testimonial data
  {
    content:
      ' "Desde una perspectiva técnica, FSA tiene un concepto muy prometedor. El diseño de los audífonos FSA One Line Pro muestra intención, claridad y enfoque en la experiencia del usuario. Es el tipo de producto que puede crecer hasta convertirse en una línea tecnológica sólida." ',
    author: "Fabián",
    role: "Físico | Biofísica Médica",
    avatarSrc:
      "https://images.unsplash.com/photo-1474176857210-7287d38d27c6?q=80&w=1470&auto=format&fit=crop&ixlib=rb-4.0.3&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80",
    avatarAlt: "Retrato de Fabián",
  },
];
---

<MainLayout
  title={pageTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://famdesc.com/es/products",
    url: "https://famdesc.com/es/products",
    name: "Productos FSA | Famdesc",
    description:
      "Descubre los FSA Line One Pro, unos auriculares con cable de alta gama de Famdesc Sound Authority.",
    isPartOf: {
      "@type": "WebSite",
      url: "https://famdesc.com/es",
      name: "Famdesc",
      description:
        "Famdesc es una empresa tecnológica centrada en las personas que comienza con productos de audio de alta gama a través de FSA, mientras construye una plataforma social familiar privada.",
    },
    inLanguage: "es-ES",
  }}
>
  <div
    class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
  >
    <div class="mb-4 flex items-center justify-between gap-8 sm:mb-8 md:mb-12">
      <div class="flex items-center gap-12">
        <h1
          class="text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight"
        >
          {title}
        </h1>
        {
          subTitle && (
            <p class="hidden max-w-screen-sm text-pretty text-neutral-600 dark:text-neutral-400 md:block">
              {subTitle}
            </p>
          )
        }
      </div>
      <PrimaryCTA
        title="Explora la FSA Line One Pro"
        url="/products/fsa-line-one-pro"
        noArrow={true}
      />
    </div>
    <!--Displaying products in alternating styles. Alternative product gets different card styling.-->
    <!--Maps through all product entries and displays them with either CardSmall or CardWide based on their position.-->
    <section class="grid grid-cols-1 gap-4 sm:grid-cols-3 md:gap-6 xl:gap-8">
      {
        product.map((product, index) => {
          const position = index % 4;
          if (position === 0 || position === 3) {
            return <CardSmall product={product} />;
          } else {
            return <CardWide product={product} />;
          }
        })
      }
    </section>
  </div>
  <!--Features statistics section-->
  <FeaturesStatsAlt
    title="¿Por qué elegir los FSA Line One Pro?"
    subTitle="Auriculares con cable de alta gama para quienes buscan un audio fiable sin problemas de carga, emparejamiento o latencia evitable."
    benefits={[
      "Sonido Hi-Fi mejorado con un controlador dinámico de 10 mm.",
      "Rendimiento con cable de baja latencia sin necesidad de batería.",
      "Aislamiento del ruido, micrófono HD, cable trenzado, carcasa metálica y compatibilidad universal de 3,5 mm.",
    ]}
  />

  <!--Testimonials section-->
  <TestimonialsSectionAlt
    title="Lo que dicen sobre FSA"
    testimonials={testimonials}
  />
</MainLayout>
