---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import ContactSection from "@components/sections/fr/ContactSection_fr.astro";
---

<!--Utilizing MainLayout for the outer layout of the page, and defining meta for SEO purposes-->
<MainLayout
  title="Contact | Famdesc"
  lang="fr"
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://famdesc.com/fr/contact",
    url: "https://famdesc.com/fr/contact",
    name: "Nous Contacter | Famdesc",
    description:
      "Vous avez des questions ou souhaitez discuter d'un projet ? Contactez-nous et élaborons ensemble la solution parfaite avec nos outils et services.",
    isPartOf: {
      "@type": "WebSite",
      url: "https://famdesc.com/fr/",
      name: "Famdesc",
      description:
        "Famdesc développe une technologie centrée sur les personnes, en commençant par des produits audio premium via FSA.",
    },
    inLanguage: "fr",
  }}
>
  <ContactSection />
</MainLayout>
