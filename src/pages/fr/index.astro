---
// Importer les composants nécessaires
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import HeroSectionAlt from "@components/sections/landing/HeroSectionAlt.astro";
import FeaturesGeneral from "@components/sections/features/FeaturesGeneral.astro";
import FeaturesNavs from "@components/sections/features/FeaturesNavs.astro";
import TestimonialsSection from "@components/sections/testimonials/TestimonialsSection.astro";
import MainSection from "@components/ui/blocks/MainSection.astro";
import FAQ from "@components/sections/misc/FAQ.astro";
import AnnouncementBanner from "@components/ui/banners/AnnouncementBanner.astro";
import heroImage from "@images/hero-image-light.avif";
import heroImageDark from "@images/hero-image-dark.avif";
import faqs from "@data/fr/faqs.json";
import features from "@data/fr/features.json";
import fsaLine from "@images/fsa-line.avif";
import fsaOneLinePro from "@images/fsa-one-line-pro.avif";
import ClientsSliderSection from "@/components/sections/landing/ClientsSliderSection.astro";
import TestimonialData from "@utils/testimonialsData";
import { famdescPromo } from "@/videos/videosLink";

const avatarSrcs: Array<string> = [
  "https://images.unsplash.com/photo-1568602471122-7832951cc4c5?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1531927557220-a9e23c1e4794?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1541101767792-f9b2b1c4f127?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&&auto=format&fit=facearea&facepad=3&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
];
---

<MainLayout lang="fr">
  <AnnouncementBanner
    title="Fièrement Open Source"
    btnId="dismiss-button"
    btnTitle="Explorez Famdesc sur GitHub"
    url="https://github.com/Famdesc/Famdesc-UI"
  />

  <HeroSection
    title=`<span class="text-salmon-500 dark:text-salmon-400">Famdesc:</span> Technologie pour les gens. Conçue pour les familles.`
    subTitle="Famdesc est une entreprise technologique centrée sur les personnes et les familles. Nous commençons avec des produits audio premium via FSA tout en construisant une future plateforme sociale familiale privée."
    primaryBtn="Explorer FSA Line One Pro"
    primaryBtnURL="/products/fsa-line-one-pro"
    secondaryBtn="Rejoindre la liste"
    secondaryBtnURL="/contact"
    withReview={true}
    avatars={avatarSrcs}
    rating=`<span class="font-bold">4.8</span> / 5`
    starCount={4}
    reviews=`Basé sur plus de <span class="font-bold">12.8k</span> avis`
    src={heroImage}
    srcDark={heroImageDark}
    alt="Bannière de l’entreprise technologique Famdesc montrant un laboratoire lumineux et minimaliste avec des diagrammes holographiques et le logo de la marque."
  />

  <FeaturesGeneral
    title="Famdesc : Technologie pour les personnes et les familles."
    subTitle="Famdesc construit une technologie pour les personnes et les familles. Notre première étape est FSA, une ligne audio premium conçue pour apporter une valeur réelle aujourd'hui tout en soutenant le développement à long terme d'une plateforme sociale familiale privée."
    src={famdescPromo}
    alt="Vidéo promotionnelle montrant l'évolution de Famdesc : des solutions matérielles haute fidélité comme la ligne audio FSA jusqu'aux outils de l'écosystème conçus pour garder les familles connectées et en sécurité."
    features={features}
  />

  <FeaturesNavs
    buttonConfig={{
      btnExists: false,
    }}
    title={`Famdesc <span class="text-salmon-500 dark:text-salmon-400">Sound Authority</span>`}
    subtitle="FSA est la première ligne technologique premium de l'écosystème Famdesc, centrée sur des produits audio fiables et utiles dès aujourd'hui."
    tabs={[
      {
        heading: "Première Ligne Premium",
        content:
          "Famdesc Sound Authority (FSA) présente la première ligne de produits réels de l'écosystème Famdesc, en commençant par l'audio intra-auriculaire filaire premium.",
        svg: "tools",
        src: fsaLine,
        alt: "Bannière de la ligne audio FSA dans un laboratoire d'ingénierie de haute performance, avec analyseurs de fréquence, bobines en cuivre et composants audio de précision.",
        first: true,
      },
      {
        heading: "Conçu pour la durabilité",
        content:
          "FSA Line One Pro offre un Enhanced Hi-Fi Sound avec transducteur dynamique de 10 mm, isolation sonore, microphone HD, câble tressé renforcé, boîtier métallique et connecteur 3,5 mm en L plaqué or.",
        svg: "dashboard",
        src: fsaOneLinePro,
        alt: "Présentation commerciale des écouteurs FSA Line One Pro mettant en avant leur finition en aluminium, câble tressé, microphone intégré et spécifications acoustiques techniques.",
        second: true,
      },
    ]}
  />

  <ClientsSliderSection
    title="Conformité en cours"
    subTitle="FSA Line One Pro est conçu pour répondre aux exigences CE, FCC, RoHS et WEEE. Les PDFs fournisseur actualisés ont été demandés avant d'utiliser des claims de certification plus forts."
    testimonialsData={TestimonialData.frSliderData}
  />

  <MainSection
    title="Présentation de FSA - Famdesc Sound Authority."
    subTitle="Produits audio filaires premium conçus pour un usage fiable, à faible latence et sans batterie."
    btnExists={true}
    btnTitle="Voir les produits FSA"
    btnURL="/products"
  />

  <TestimonialsSection
    title="La plateforme sociale Famdesc (en développement)"
    subTitle="Nous développons le prochain chapitre de Famdesc : une future plateforme sociale construite sur notre socle technologique. À mesure que Famdesc Technology se développe avec des gammes comme FSA, nous continuons à bâtir des outils sociaux significatifs qui aident les familles à rester connectées."
    testimonials={[
      {
        content:
          "Famdesc a commencé comme une vision sociale et évolue désormais vers une entreprise technologique qui crée d'abord des produits réels. Ce parcours nous permet de financer une innovation durable et de revenir plus forts avec une plateforme conçue pour connecter les familles de manière plus profonde et pratique.",
        author: "Équipe Famdesc",
        role: "Vision Technologie & Communauté",
        avatarSrc:
          "https://raw.githubusercontent.com/nardis9501/avatar/main/yuri.avif",
      },
    ]}
    statistics={[
      {
        count: "1er",
        description:
          "ligne technologique lancée par Famdesc Sound Authority comme la première étape de notre stratégie parapluie.",
      },
      {
        count: "Futur",
        description:
          "plateforme sociale en planification active, appuyée par l'expérience réelle de développement produit et les retours de la communauté.",
      },
      {
        count: "Réel",
        description:
          "approche solutions-first pour financer la croissance et soutenir l'innovation à long terme pour les familles.",
      },
      {
        count: "Famille",
        description:
          "mission centrale préservée : créer une technologie qui aide les gens à rester connectés entre les générations.",
      },
    ]}
  />

  <FAQ title="Questions<br />Fréquemment Posées" faqs={faqs} />

  <HeroSectionAlt
    title="Construisons Ensemble"
    subTitle="Famdesc combine la collaboration open source avec une protection commerciale responsable. Le frontend est ouvert afin que les développeurs puissent l’explorer et y contribuer, tandis que le backend reste disponible à l’audit afin de soutenir la transparence, la sécurité et une croissance durable."
    url="https://github.com/Famdesc/Famdesc-UI"
  />
</MainLayout>
