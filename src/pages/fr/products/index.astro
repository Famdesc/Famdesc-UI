---
// Importing necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import CardSmall from "@components/ui/cards/CardSmall.astro";
import CardWide from "@components/ui/cards/CardWide.astro";
import FeaturesStatsAlt from "@components/sections/features/FeaturesStatsAlt.astro";
import TestimonialsSectionAlt from "@components/sections/testimonials/TestimonialsSectionAlt.astro";

// Importing necessary functions from Astro
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

// Fetching all the product related content and sorting it by main.id
const product: CollectionEntry<"products">[] = (
  await getCollection("products")
).sort(
  (a: CollectionEntry<"products">, b: CollectionEntry<"products">) =>
    a.data.main.id - b.data.main.id,
);

// Define variables for page content
const title: string = "Produits FSA";
const subTitle: string =
  "Famdesc Sound Authority est la première gamme technologique haut de gamme au sein de l'écosystème Famdesc. Notre produit phare actuel est le FSA Line One Pro, un casque intra-auriculaire filaire conçu pour offrir une écoute fiable à faible latence, sans piles ni recharges.";

// Testimonial data that will be rendered in the component
const testimonials = [
  // First testimonial data
  {
    content:
      ' "FSA donne l’impression d’une marque avec une vision claire : une technologie moderne, utile et créée avec attention aux détails. Les écouteurs FSA One Line Pro sont élégants, pratiques et pensés pour la vie quotidienne. C’est motivant de voir un produit avec autant d’identité et d’ambition." ',
    author: "Lian Steffan",
    role: "Étudiant en Stomatologie",
    avatarSrc:
      "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=1374&auto=format&fit=crop&ixlib=rb-4.0.3&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80",
    avatarAlt: "Portrait de Lian Steffan",
  },
  // Second testimonial data
  {
    content:
      ' "Ce que j’apprécie le plus chez FSA, c’est la façon dont le produit combine style, technologie et une forte présence de marque. Les écouteurs semblent conçus non seulement pour être utilisés, mais aussi pour représenter la confiance, le progrès et le bon goût." ',
    author: "Emine",
    role: "Étudiante et professionnelle dans le commerce",
    avatarSrc:
      "https://images.unsplash.com/photo-1544005313-94ddf0286df2?q=80&w=1376&auto=format&fit=crop&ixlib=rb-4.0.3&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80",
    avatarAlt: "Portrait d’Emine",
  },
  // Third testimonial data
  {
    content:
      ' "D’un point de vue technique, FSA possède un concept très prometteur. Le design des écouteurs FSA One Line Pro montre de l’intention, de la clarté et une attention réelle à l’expérience utilisateur. C’est le type de produit qui peut devenir une ligne technologique solide." ',
    author: "Fabián",
    role: "Physicien | Biophysique médicale",
    avatarSrc:
      "https://images.unsplash.com/photo-1474176857210-7287d38d27c6?q=80&w=1470&auto=format&fit=crop&ixlib=rb-4.0.3&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80",
    avatarAlt: "Portrait de Fabián",
  },
];
---

<MainLayout
  title="Produits FSA | Famdesc"
  lang="fr"
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://famdesc.com/fr/products",
    url: "https://famdesc.com/fr/products",
    name: "Produits FSA | Famdesc",
    description:
      "Découvrez FSA Line One Pro, des écouteurs filaires premium par Famdesc Sound Authority.",
    isPartOf: {
      "@type": "WebSite",
      url: "https://famdesc.com/fr",
      name: "Famdesc",
      description:
        "Famdesc est une entreprise technologique centrée sur les personnes, qui commence par des produits audio premium avec FSA.",
    },
    inLanguage: "fr",
  }}
>
  <div
    class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
  >
    <div class="mb-4 flex items-center justify-between gap-8 sm:mb-8 md:mb-12">
      <div class="flex items-center gap-12">
        <h1
          class="text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight"
        >
          {title}
        </h1>
        {
          subTitle && (
            <p class="hidden max-w-screen-sm text-pretty text-neutral-600 dark:text-neutral-400 md:block">
              {subTitle}
            </p>
          )
        }
      </div>
      <PrimaryCTA
        title="Explorer FSA Line One Pro"
        url="/products/fsa-line-one-pro"
        noArrow={true}
      />
    </div>
    <!--Displaying products in alternating styles. Alternative product gets different card styling.-->
    <!--Maps through all product entries and displays them with either CardSmall or CardWide based on their position.-->
    <section class="grid grid-cols-1 gap-4 sm:grid-cols-3 md:gap-6 xl:gap-8">
      {
        product.map((product, index) => {
          const position = index % 4;
          if (position === 0 || position === 3) {
            return <CardSmall product={product} />;
          } else {
            return <CardWide product={product} />;
          }
        })
      }
    </section>
  </div>
  <!--Features statistics section-->
  <FeaturesStatsAlt
    title="Pourquoi choisir FSA Line One Pro ?"
    subTitle="Des écouteurs filaires premium pour une écoute fiable, sans recharge, sans appairage et avec une latence réduite."
    benefits={[
      "Enhanced Hi-Fi Sound avec transducteur dynamique de 10 mm.",
      "Performance filaire à faible latence, sans batterie.",
      "Isolation sonore, microphone HD, câble tressé, boîtier métallique et compatibilité universelle 3,5 mm.",
    ]}
  />
  <!--Testimonials section-->
  <TestimonialsSectionAlt
    title="Ce que l’on dit de FSA"
    testimonials={testimonials}
  />
</MainLayout>
