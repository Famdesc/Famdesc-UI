---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import HeroSectionAlt from "@components/sections/landing/HeroSectionAlt.astro";
import FeaturesGeneral from "@components/sections/features/FeaturesGeneral.astro";
import FeaturesNavs from "@components/sections/features/FeaturesNavs.astro";
import TestimonialsSection from "@components/sections/testimonials/TestimonialsSection.astro";
import MainSection from "@components/ui/blocks/MainSection.astro";
import FAQ from "@components/sections/misc/FAQ.astro";
import AnnouncementBanner from "@components/ui/banners/AnnouncementBanner.astro";
import heroImage from "@images/hero-image.avif";
import faqs from "@data/faqs.json";
import features from "@data/features.json";
import fsaLine from "@images/fsa-line.avif";
import fsaOneLinePro from "@images/fsa-one-line-pro.avif";
import famdescUmbrella from "@images/famdesc-umbrella.avif";
import ClientsSliderSection from "@/components/sections/landing/ClientsSliderSection.astro";
import TestimonialData from "@utils/testimonialsData";
import { famdescPromo } from "@/videos/videosLink";

const avatarSrcs: Array<string> = [
  "https://images.unsplash.com/photo-1568602471122-7832951cc4c5?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1531927557220-a9e23c1e4794?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1541101767792-f9b2b1c4f127?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&&auto=format&fit=facearea&facepad=3&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
];
---

<MainLayout>
  <AnnouncementBanner
    title="Proudly Open Source"
    btnId="dismiss-button"
    btnTitle="Explore Famdesc on GitHub"
    url="https://github.com/Famdesc/Famdesc-UI"
  />
  <HeroSection
    title=`<span
        class="text-salmon-500 dark:text-salmon-400">Famdesc:</span>
      Technology for People. Built for Families.`
    subTitle="Famdesc is building a technology ecosystem focused on connection, quality and long-term value."
    primaryBtn="Donate Now"
    openInNewTab={true}
    primaryBtnURL="https://www.gofundme.com/famdesc"
    secondaryBtn="Contact Our Team"
    secondaryBtnURL="/contact"
    withReview={true}
    avatars={avatarSrcs}
    rating=`<span class="font-bold">4.8</span> / 5`
    starCount={4}
    reviews=`From Over <span class="font-bold">12.8k</span> Reviews`
    src={heroImage}
    alt="Multigenerational family gathered and smiling"
  />

  <FeaturesGeneral
    title="Discover Famdesc: Our Vision And Core Values."
    subTitle="Famdesc is a technology initiative focused on building tools that improve everyday life and strengthen family connections. We are evolving from a social network in pause into a technology company delivering real solutions today while building the foundation for our future social platform."
    src={famdescPromo}
    alt="Promotional video showcasing the evolution of Famdesc: from high-fidelity hardware solutions like the FSA audio line, to ecosystem tools designed to keep families connected and secure."
    features={features}
  />

  <FeaturesNavs
    buttonConfig={{
      btnExists: false,
    }}
    title=`Famdesc <span class="text-salmon-500 dark:text-salmon-400">Technology</span>`
    tabs={[
      {
        heading: "Technology Product Line",
        content:
          "Our inaugural technology vertical is Famdesc Sound Authority (FSA), introducing high-fidelity, laboratory-tested hardware engineering that sets the quality and performance benchmark for all future Famdesc subsidiaries.",
        svg: "tools",
        src: fsaLine,
        alt: "FSA (Famdesc Sound Authority) technology line banner inside an engineering laboratory featuring frequency analyzers, copper coils, and precision audio hardware components.",
        first: true,
      },
      {
        heading: "Built for Durability",
        content:
          "The FSA Line One Pro delivers professional sound that connects you. Engineered with premium braided tangle-free cables, aluminum acoustic cavities, an integrated high-definition microphone, a gold-plated 3.5mm jack, and tailored for an extra-bass powerful audio response with a comfortable everyday fit.",
        svg: "dashboard",
        src: fsaOneLinePro,
        alt: "Commercial showcase of FSA Line One Pro wired earphones highlighting its aluminum build, braided cable, inline control microphone, and technical acoustic specifications.",
        second: true,
      },
      {
        heading: "Umbrella Brand Vision",
        content:
          "Grounded in fundamental physics and bleeding-edge engineering, Famdesc operates as a high-tech umbrella corporation. From consumer mobile devices and computing to bold future frontiers in satellite networks, aerospace travel, smart automotive systems, and medical health-tech, we develop advanced technology designed purely for humanity.",
        svg: "features",
        src: famdescUmbrella,
        alt: "Abstract minimalist representation of the Famdesc umbrella brand ecosystem, featuring soft light rays and connected vectors of multi-industry technologies converging into a bright, human-centered environment.",
      },
    ]}
  />

  <ClientsSliderSection
    title="Technical Validation, Human Commitment"
    subTitle="Our physical products comply with the strictest international standards, strengthening the economic and technological foundation of the future Famdesc ecosystem."
    testimonialsData={TestimonialData.usSliderData}
  />

  <MainSection
    title="Introducing FSA - Famdesc Sound Authority."
    subTitle="Professional audio products designed with attention to detail, durability, and sound fidelity."
    btnExists={true}
    btnTitle="View Products"
    btnURL="/products"
  />

  <TestimonialsSection
    title="The Famdesc Social Platform (Coming Soon)"
    subTitle="We are developing the next chapter of Famdesc: a future social platform built on top of our technology company foundation. As Famdesc Technology grows through product lines like FSA, we continue building toward meaningful social tools that help families stay connected."
    testimonials={[
      {
        content:
          "Famdesc began as a social vision and is now evolving into a technology company that creates real products first. This path allows us to finance sustainable innovation and return stronger with a platform designed to connect families in deeper, more practical ways.",
        author: "Famdesc Team",
        role: " Technology & Community Vision",
        avatarSrc:
          "https://raw.githubusercontent.com/nardis9501/avatar/main/yuri.avif",
      },
    ]}
    statistics={[
      {
        count: "1st",
        description:
          "technology line launched through Famdesc Sound Authority as the first step of our umbrella-brand strategy.",
      },
      {
        count: "Future",
        description:
          "social platform in active planning, informed by real product-building experience and community feedback.",
      },
      {
        count: "Real",
        description:
          "solutions-first approach to finance growth and sustain long-term innovation for families.",
      },
      {
        count: "Family",
        description:
          "core mission preserved: build technology that helps people stay connected across generations.",
      },
    ]}
  />

  <FAQ title="Frequently<br />asked questions" faqs={faqs} />

  <HeroSectionAlt
    title="Let's Build Together"
    subTitle="Famdesc is an open-source template, meticulously crafted with Astro, Tailwind CSS, and Preline UI frameworks."
    url="https://github.com/nardis9501/Famdesc-landing-blog"
  />
</MainLayout>
