---
// Import the necessary dependencies
import { Image } from "astro:assets";
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import SecondaryCTA from "@components/ui/buttons/SecondaryCTA.astro";
import ReviewComponent from "@components/ui/blocks/ReviewComponent.astro";

// Define props from Astro
const {
  title,
  subTitle,
  primaryBtn,
  primaryBtnURL,
  openInNewTab,
  secondaryBtn,
  secondaryBtnURL,
  withReview,
  avatars,
  starCount,
  rating,
  reviews,
  src,
  srcDark, // <-- map for optional dark mode image source
  alt,
} = Astro.props;

// Define TypeScript interface for props
interface Props {
  title: string;
  subTitle?: string;
  primaryBtn?: string;
  primaryBtnURL?: string;
  openInNewTab?: boolean;
  secondaryBtn?: string;
  secondaryBtnURL?: string;
  withReview?: boolean;
  avatars?: Array<string>;
  starCount?: number;
  rating?: string;
  reviews?: string;
  src?: any;
  srcDark?: any; // <-- map for optional dark mode image source
  alt?: string;
}
---

<section
  class="mx-auto grid max-w-[85rem] gap-4 px-4 py-14 sm:px-6 md:grid-cols-2 md:items-center md:gap-8 lg:px-8 2xl:max-w-full"
>
  <div>
    <h1
      class="block text-balance text-3xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 sm:text-4xl lg:text-6xl lg:leading-tight"
    >
      <Fragment set:html={title} />
    </h1>
    {
      subTitle && (
        <p class="mt-3 text-pretty text-lg leading-relaxed text-neutral-700 dark:text-neutral-400 lg:w-4/5">
          {subTitle}
        </p>
      )
    }
    <div class="mt-7 grid w-full gap-3 sm:inline-flex">
      {
        primaryBtn && (
          <PrimaryCTA
            title={primaryBtn}
            url={primaryBtnURL}
            openInNewTab={openInNewTab}
          />
        )
      }
      {
        secondaryBtn && (
          <SecondaryCTA title={secondaryBtn} url={secondaryBtnURL} />
        )
      }
    </div>

    {
      withReview ? (
        <ReviewComponent
          avatars={avatars}
          starCount={starCount}
          rating={rating}
          reviews={reviews}
        />
      ) : (
        ""
      )
    }
  </div>
  <!-- Hero Image Section -->
  <div class="flex w-full">
    <div class="top-12 w-full overflow-hidden">
      {
        src && alt && (
          // Is srcDark provided? If yes, render both images and use CSS to show/hide based on the theme. If not, just render the single image as before.
          <>
            <Image
              src={src}
              alt={alt}
              class={`h-full w-full scale-100 rounded-xl object-cover object-center ${srcDark ? "block dark:hidden" : ""}`}
              draggable={"false"}
              loading={"eager"}
              format={"avif"}
            />
            {srcDark && (
              <Image
                src={srcDark}
                alt={alt}
                class="hidden h-full w-full scale-100 rounded-xl object-cover object-center dark:block"
                draggable={"false"}
                loading={"eager"}
                format={"avif"}
              />
            )}
          </>
        )
      }
    </div>
  </div>
</section>
